ROM_START			equ $000000
ROM_SIZE			equ $40000

WORK_RAM			equ $ff8000
WORK_RAM_SIZE			equ $8000
WORK_RAM_ADDRESS_LINES		equ 15
WORK_RAM_MASK			equ $ffff

PALETTE_RAM			equ $fd8000
PALETTE_RAM_SIZE		equ $800
PALETTE_RAM_ADDRESS_LINES	equ 11
PALETTE_RAM_MASK		equ $ffff
PALETTE_SIZE			equ $40

; sprirt ram is $1000 size, but sprite data
; starts at +$800 offset
SPRITE_RAM			equ $fc0000
SPRITE_RAM_SIZE			equ $1000
SPRITE_RAM_ADDRESS_LINES	equ 12
SPRITE_RAM_MASK			equ $ffff
SPRITE_PALETTE			equ PALETTE_RAM + $400
SPRITE_PALETTE_SIZE		equ $20

FIX_TILE_RAM			equ $fcc000
FIX_TILE_RAM_SIZE		equ $1000
FIX_TILE_RAM_ADDRESS_LINES	equ 12
FIX_TILE_RAM_MASK		equ $ffff
FIX_TILE_PALETTE		equ PALETTE_RAM + $600
FIX_TILE_PALETTE_SIZE		equ $8

FG_TILE_RAM			equ $fd0000
FG_TILE_RAM_SIZE		equ $4000
FG_TILE_RAM_ADDRESS_LINES	equ 14
FG_TILE_RAM_MASK		equ $ffff
FG_TILE_PALETTE			equ PALETTE_RAM + $200
FG_TILE_PALETTE_SIZE		equ $20

BG_TILE_RAM			equ $fd4000
BG_TILE_RAM_SIZE		equ $4000
BG_TILE_RAM_ADDRESS_LINES	equ 14
BG_TILE_RAM_MASK		equ $ffff
BG_TILE_PALETTE			equ PALETTE_RAM
BG_TILE_PALETTE_SIZE		equ $20

REG_SOUND			equ $fc4003
REG_FG_SCROLL_X			equ $fc8002
REG_FG_SCROLL_Y			equ $fc8000
REG_BG_SCROLL_X			equ $fc8006
REG_BG_SCROLL_Y			equ $fc8004
REG_SPRITE_COPY_REQUEST		equ $fc8008

REG_INPUT_DSW1			equ $fc4005
REG_INPUT_DSW2			equ $fc4004
REG_INPUT_DSW3			equ $fc4007
REG_INPUT_P1			equ $fc4001
REG_INPUT_P2			equ $fc4000
REG_INPUT_SYSTEM		equ $fc4003

CHAR_COLON			equ $1a

SOUND_NUM_STOP			equ $ff

	macro WATCHDOG
	endm

	macro SOUND_PLAY
		move.b	#$0, REG_SOUND
		move.w	#$1fff, d1
	.\@:
		dbra	d1, .\@
		move.b	d0, REG_SOUND
	endm

	macro SOUND_STOP
		move.b	#$0, REG_SOUND
	endm
