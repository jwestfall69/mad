	macro	WATCHDOG
	endm

	macro	SOUND_PLAY
		tfr	d, y

		lda	#$00
		sta	REG_SOUND

		DELAY	#$1ff


		lda	#$fe
		sta	REG_SOUND

		DELAY	#$1ff

		tfr	y, d
		sta	REG_SOUND

	endm

	macro	SOUND_STOP
		lda	#$00
		sta	REG_SOUND

		DELAY	#$1ff

		lda	#$fe
		sta	REG_SOUND
	endm

