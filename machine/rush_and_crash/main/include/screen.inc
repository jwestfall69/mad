; visible tile area
SCREEN_NUM_COLUMNS		equ 30
SCREEN_NUM_ROWS			equ 44

; total tile area
SCREEN_TILES_PER_COLUMN		equ 44
SCREEN_TILES_PER_ROW		equ 32 ; ?

SCREEN_BYTES_PER_TILE		equ 2
SCREEN_BYTES_PER_ROW		equ (SCREEN_BYTES_PER_TILE * SCREEN_TILES_PER_ROW)

	macro	SEEK_XY
		ldx	#(FG_TILE_RAM + $d42 + (\1 * SCREEN_BYTES_PER_TILE) - (\2 * SCREEN_BYTES_PER_ROW))
	endm
